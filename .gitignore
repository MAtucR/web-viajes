# ─────────────────────────────────────────────────────────────────────────────
# .gitignore
# ─────────────────────────────────────────────────────────────────────────────

# ── Secretos — NUNCA commitear ────────────────────────────────────────────────
.env
.env.local
.env.*.local
# ⚠ El secrets.yaml de k8s tampoco debería commitearse con valores reales
# Usá Sealed Secrets o External Secrets Operator en su lugar
k8s/secrets.yaml

# ── Next.js ───────────────────────────────────────────────────────────────────
.next/
out/
build/

# ── Node.js ───────────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Prisma ────────────────────────────────────────────────────────────────────
prisma/*.db
prisma/*.db-journal

# ── Testing ───────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.sw?

# ── Sistema operativo ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Misc ─────────────────────────────────────────────────────────────────────
*.pem
.vercel
