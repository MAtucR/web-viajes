# ─────────────────────────────────────────────────────────────────────────────
# .dockerignore — excluye todo lo que no necesita el build de Docker
# Reduce drásticamente el tamaño del contexto enviado al daemon
# ─────────────────────────────────────────────────────────────────────────────

# Dependencias (se reinstalan en el Dockerfile)
node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build de Next.js (se regenera en el Dockerfile)
.next
out

# Variables de entorno — NUNCA incluir en la imagen
.env
.env.*
!.env.example

# Control de versiones
.git
.gitignore
.github

# Herramientas de desarrollo
.eslintcache
.prettierrc*
.editorconfig
*.log

# Tests
__tests__
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
coverage
.nyc_output

# Docker (no recursivo)
Dockerfile*
docker-compose*
.dockerignore

# Documentación
README.md
docs
*.md

# IDE
.vscode
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Sistema operativo
.DS_Store
Thumbs.db

# Prisma migrations backup (el schema y migrations sí se incluyen)
prisma/*.db
prisma/*.db-journal
