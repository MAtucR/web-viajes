# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copiá este archivo a .env y completá los valores
# cp .env.example .env
#
# ⚠  NUNCA commitear el archivo .env real. Está en .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=moni
POSTGRES_PASSWORD=cambia_esta_password_segura
POSTGRES_DB=viajaconmoni

# ── Prisma ────────────────────────────────────────────────────────────────────
# En Docker Compose el hostname es el nombre del servicio ("postgres")
# En desarrollo local directo (sin Docker) usá "localhost"
DATABASE_URL="postgresql://moni:cambia_esta_password_segura@postgres:5432/viajaconmoni?schema=public"

# ── NextAuth.js (si lo usás) ──────────────────────────────────────────────────
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=genera_un_secreto_aleatorio_con_openssl
NEXTAUTH_URL=http://localhost:3000

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
